# Default model used when --model is omitted.
LLM_DEFAULT_MODEL=qwen3-8b

# DashScope models can share the same provider credentials.
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=sk-your-key

LLM_QWEN3_8B_BASE_URL=${DASHSCOPE_BASE_URL}
LLM_QWEN3_8B_API_KEY=${DASHSCOPE_API_KEY}
LLM_QWEN3_8B_ENABLE_THINKING=false

LLM_QWEN3_14B_BASE_URL=${DASHSCOPE_BASE_URL}
LLM_QWEN3_14B_API_KEY=${DASHSCOPE_API_KEY}
LLM_QWEN3_14B_ENABLE_THINKING=false

# OpenAI-compatible vLLM server.
LLM_LLAMA3_8B_BASE_URL=http://127.0.0.1:18080/v1
LLM_LLAMA3_8B_API_KEY=EMPTY
LLM_LLAMA3_8B_MODEL=llama3-8b
LLM_LLAMA3_8B_ENABLE_THINKING=

# Legacy OPENAI_* variables are still accepted as fallback values.
